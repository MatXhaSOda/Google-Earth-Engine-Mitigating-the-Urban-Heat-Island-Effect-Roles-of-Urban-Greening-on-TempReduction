  ee.Feature(ee.Geometry.Point([114.15000, 22.66000]), {point_id: 'P13'}),
  ee.Feature(ee.Geometry.Point([114.16000, 22.67000]), {point_id: 'P14'}),
  ee.Feature(ee.Geometry.Point([114.17000, 22.68000]), {point_id: 'P15'}),
  ee.Feature(ee.Geometry.Point([114.18000, 22.69000]), {point_id: 'P16'}),
  ee.Feature(ee.Geometry.Point([114.19000, 22.70000]), {point_id: 'P17'}),
  ee.Feature(ee.Geometry.Point([114.20000, 22.71000]), {point_id: 'P18'}),
