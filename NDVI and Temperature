// =====================================
// 0) Study area
// =====================================
var sz = ee.Geometry.Rectangle([113.75, 22.45, 114.65, 22.85]);
Map.centerObject(sz, 10);
Map.addLayer(sz, {}, 'Shenzhen ROI');

// =====================================
// 1) Define your points here
// Replace coordinates and point_id with your own
// =====================================
var points = ee.FeatureCollection([
  ee.Feature(ee.Geometry.Point([114.02807, 22.57742]), {point_id: 'P1'}),
  ee.Feature(ee.Geometry.Point([114.03494, 22.63542]), {point_id: 'P2'}),
  ee.Feature(ee.Geometry.Point([114.05000, 22.56000]), {point_id: 'P3'}),
  ee.Feature(ee.Geometry.Point([114.06000, 22.57000]), {point_id: 'P4'}),
  ee.Feature(ee.Geometry.Point([114.07000, 22.58000]), {point_id: 'P5'}),
  ee.Feature(ee.Geometry.Point([114.08000, 22.59000]), {point_id: 'P6'}),
  ee.Feature(ee.Geometry.Point([114.09000, 22.60000]), {point_id: 'P7'}),
  ee.Feature(ee.Geometry.Point([114.10000, 22.61000]), {point_id: 'P8'}),
  ee.Feature(ee.Geometry.Point([114.11000, 22.62000]), {point_id: 'P9'}),
  ee.Feature(ee.Geometry.Point([114.12000, 22.63000]), {point_id: 'P10'}),
  ee.Feature(ee.Geometry.Point([114.13000, 22.64000]), {point_id: 'P11'}),
