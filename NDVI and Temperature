]);

Map.addLayer(points, {color: 'red'}, 'Sample points');

// =====================================
// 2) Buffer each point to reduce noise
// =====================================
var bufferedPoints = points.map(function(f) {
  return f.buffer(120).copyProperties(f);
});

// =====================================
// 3) Cloud mask + scaling for Landsat 8/9
// =====================================
function maskAndScaleLandsat(image) {
  var qa = image.select('QA_PIXEL');

  var dilatedCloud = 1 << 1;
  var cirrus       = 1 << 2;
  var cloud        = 1 << 3;
  var cloudShadow  = 1 << 4;
  var snow         = 1 << 5;

  var mask = qa.bitwiseAnd(dilatedCloud).eq(0)
    .and(qa.bitwiseAnd(cirrus).eq(0))
    .and(qa.bitwiseAnd(cloud).eq(0))
    .and(qa.bitwiseAnd(cloudShadow).eq(0))
    .and(qa.bitwiseAnd(snow).eq(0));

  var optical = image.select([
    'SR_B2', 'SR_B3', 'SR_B4', 'SR_B5', 'SR_B6', 'SR_B7'
  ]).multiply(0.0000275).add(-0.2);

  return image
    .addBands(optical, null, true)
    .updateMask(mask)
    .copyProperties(image, image.propertyNames());
}

// =====================================
// 4) Year list
// =====================================
var years = ee.List.sequence(2013, 2025);

// =====================================
// 5) Annual NDVI image
// =====================================
function getAnnualNDVI(year) {
  year = ee.Number(year);
  var start = ee.Date.fromYMD(year, 1, 1);
  var end   = ee.Date.fromYMD(year, 12, 31);

  var l8 = ee.ImageCollection('LANDSAT/LC08/C02/T1_L2')
    .filterBounds(sz)
    .filterDate(start, end)
    .map(maskAndScaleLandsat);

  var l9 = ee.ImageCollection('LANDSAT/LC09/C02/T1_L2')
    .filterBounds(sz)
    .filterDate(start, end)
    .map(maskAndScaleLandsat);

  return l8.merge(l9)
    .map(function(img) {
      return img.normalizedDifference(['SR_B5', 'SR_B4']).rename('NDVI');
    })
    .mean();
}

// =====================================
// 6) Annual LST image
// =====================================
function getAnnualLST(year) {
  year = ee.Number(year);
  var start = ee.Date.fromYMD(year, 1, 1);
  var end   = ee.Date.fromYMD(year, 12, 31);

  return ee.ImageCollection('MODIS/061/MOD11A2')
    .filterBounds(sz)
    .filterDate(start, end)
    .select('LST_Day_1km')
    .mean()
    .multiply(0.02)
    .subtract(273.15)
    .rename('LST_C');
}

// =====================================
// 7) Extract by point, then by year
// This order makes each point's years stay together
// =====================================
var pointList = bufferedPoints.toList(bufferedPoints.size());

var allData = ee.FeatureCollection(
  ee.List.sequence(0, bufferedPoints.size().subtract(1)).map(function(i) {
    var pt = ee.Feature(pointList.get(i));
    var pointID = pt.get('point_id');

    var yearlyRows = ee.FeatureCollection(
      years.map(function(y) {
        y = ee.Number(y);

        var ndviImage = getAnnualNDVI(y);
        var lstImage = getAnnualLST(y);

        var ndviVal = ndviImage.reduceRegion({
          reducer: ee.Reducer.mean(),
          geometry: pt.geometry(),
          scale: 30,
          maxPixels: 1e13
        }).get('NDVI');

        var lstVal = lstImage.reduceRegion({
          reducer: ee.Reducer.mean(),
          geometry: pt.geometry(),
          scale: 1000,
          maxPixels: 1e13
        }).get('LST_C');

        return ee.Feature(null, {
          point_id: pointID,
          year: y,
          LST_C: lstVal,
          NDVI: ndviVal
        });
      })
    );

    return yearlyRows;
  })
).flatten();

// =====================================
// 8) Keep only 4 columns
// =====================================
var finalTable = allData.select(['point_id', 'year', 'LST_C', 'NDVI']);

print('Point-year NDVI + LST table', finalTable);

// =====================================
// 9) Export to CSV
// =====================================
Export.table.toDrive({
  collection: finalTable,
  description: 'Shenzhen_20Points_LST_NDVI_2013_2025',
  fileFormat: 'CSV'
});
